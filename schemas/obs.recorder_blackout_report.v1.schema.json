{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "obs.recorder_blackout_report.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "target_id",
    "incident_id",
    "window_id",
    "time_range_mono_ns",
    "blackout_detected",
    "sources",
    "data_quality"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["obs.recorder_blackout_report.v1"]},
    "target_id": {"type": "string", "minLength": 1},
    "incident_id": {"type": "string", "minLength": 1},
    "window_id": {"type": "string", "minLength": 1},
    "time_range_mono_ns": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {"type": "integer", "minimum": 0},
        "end": {"type": "integer", "minimum": 0}
      }
    },
    "blackout_detected": {"type": "boolean"},
    "sources": {
      "type": "array",
      "items": {"$ref": "obs.recorder_log_source_status.v1.schema.json"}
    },
    "data_quality": {"$ref": "obs.data_quality.v1.schema.json"}
  }
}
