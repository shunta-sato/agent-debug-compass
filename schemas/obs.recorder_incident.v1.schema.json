{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "obs.recorder_incident.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "incident_id",
    "target_id",
    "incident_state",
    "previous_state",
    "marker_id",
    "freeze_reason",
    "frozen_window_ref",
    "loss_report_ref",
    "created_at_mono_ns",
    "updated_at_mono_ns",
    "data_quality"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["obs.recorder_incident.v1"]},
    "incident_id": {"type": "string", "minLength": 1},
    "target_id": {"type": "string", "minLength": 1},
    "incident_state": {"type": "string", "enum": ["marker_received", "pre_window_selected", "post_window_collecting", "freezing", "frozen", "expired", "exported", "discarded"]},
    "previous_state": {"type": ["string", "null"], "enum": ["marker_received", "pre_window_selected", "post_window_collecting", "freezing", "frozen", "expired", "exported", "discarded", null]},
    "marker_id": {"type": ["string", "null"]},
    "freeze_reason": {"type": "string", "enum": ["external_marker", "operator_marker", "agent_marker", "trigger_policy", "budget_guard", "daemon_shutdown"]},
    "frozen_window_ref": {"type": ["string", "null"]},
    "loss_report_ref": {"type": ["string", "null"]},
    "created_at_mono_ns": {"type": "integer", "minimum": 0},
    "updated_at_mono_ns": {"type": "integer", "minimum": 0},
    "data_quality": {"$ref": "obs.data_quality.v1.schema.json"}
  }
}
