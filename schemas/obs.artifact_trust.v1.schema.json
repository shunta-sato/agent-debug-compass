{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "obs.artifact_trust.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "raw_ref", "content_class", "trust_level", "agent_instruction_policy", "secret_scan", "prompt_injection_scan", "data_quality"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["obs.artifact_trust.v1"]},
    "raw_ref": {"type": "string"},
    "content_class": {
      "type": "string",
      "enum": ["log", "journal", "domain_event", "config", "telemetry", "trace", "metric_series", "service_state", "process_snapshot", "manifest", "evidence_index", "window", "context", "summary", "artifact", "binary"]
    },
    "trust_level": {
      "type": "string",
      "enum": ["trusted_system", "trusted_adc_generated", "untrusted_target_text", "untrusted_user_provided_text", "opaque_artifact"]
    },
    "agent_instruction_policy": {"type": "string", "enum": ["treat_as_data_only"]},
    "secret_scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "redaction_applied", "suspected_secret_count"],
      "properties": {
        "status": {"type": "string", "enum": ["scanned"]},
        "redaction_applied": {"type": "boolean"},
        "suspected_secret_count": {"type": "integer"}
      }
    },
    "prompt_injection_scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "markers", "severity"],
      "properties": {
        "status": {"type": "string", "enum": ["scanned"]},
        "markers": {"type": "array", "items": {"type": "string"}},
        "severity": {"type": "string", "enum": ["none", "low", "medium", "high"]}
      }
    },
    "data_quality": {"$ref": "obs.data_quality.v1.schema.json"}
  }
}
