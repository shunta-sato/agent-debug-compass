{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "obs.recorder_power_policy.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy_id", "modes", "data_quality"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["obs.recorder_power_policy.v1"]},
    "policy_id": {"type": "string", "minLength": 1},
    "modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "mode",
          "max_samples_per_second",
          "max_retention_ms",
          "low_priority_signals_enabled",
          "data_quality"
        ],
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["unknown", "ac_power", "battery_normal", "battery_low", "battery_critical"]
          },
          "max_samples_per_second": {"type": "integer", "minimum": 1},
          "max_retention_ms": {"type": "integer", "minimum": 1},
          "low_priority_signals_enabled": {"type": "boolean"},
          "data_quality": {"$ref": "obs.data_quality.v1.schema.json"}
        }
      }
    },
    "data_quality": {"$ref": "obs.data_quality.v1.schema.json"}
  }
}
