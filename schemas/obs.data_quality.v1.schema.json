{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "obs.data_quality.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["dropped", "drop_count", "throttled", "missing", "truncated", "clock_confidence", "notes"],
  "properties": {
    "dropped": {"type": "boolean"},
    "drop_count": {"type": "integer", "minimum": 0},
    "throttled": {"type": "boolean"},
    "missing": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "truncated": {"type": "boolean"},
    "clock_confidence": {"type": "string", "enum": ["unknown", "low", "medium", "high"]},
    "notes": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
