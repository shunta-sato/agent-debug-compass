{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "obs.recorder_frozen_window.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "window_id",
    "incident_id",
    "target_id",
    "marker_id",
    "freeze_reason",
    "preservation_reason",
    "time_range_mono_ns",
    "pre_window_ms",
    "post_window_ms",
    "persistence",
    "artifact_refs",
    "loss_report",
    "data_quality"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["obs.recorder_frozen_window.v1"]},
    "window_id": {"type": "string", "minLength": 1},
    "incident_id": {"type": "string", "minLength": 1},
    "target_id": {"type": "string", "minLength": 1},
    "marker_id": {"type": ["string", "null"]},
    "freeze_reason": {"type": "string", "enum": ["external_marker", "operator_marker", "agent_marker", "trigger_policy", "budget_guard", "daemon_shutdown"]},
    "preservation_reason": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name"],
      "properties": {
        "kind": {"type": "string", "enum": ["external_marker", "operator_marker", "agent_marker", "trigger_policy", "budget_guard", "daemon_shutdown"]},
        "name": {"type": "string", "minLength": 1}
      }
    },
    "time_range_mono_ns": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {"type": "integer", "minimum": 0},
        "end": {"type": "integer", "minimum": 0}
      }
    },
    "pre_window_ms": {"type": "integer", "minimum": 0},
    "post_window_ms": {"type": "integer", "minimum": 0},
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["persistence_mode", "survives_daemon_restart", "survives_target_reboot", "bounded_by"],
      "properties": {
        "persistence_mode": {"type": "string", "enum": ["bounded_artifact_bundle"]},
        "survives_daemon_restart": {"type": "boolean"},
        "survives_target_reboot": {"type": "boolean"},
        "bounded_by": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "artifact_refs": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "loss_report": {"$ref": "obs.loss_report.v1.schema.json"},
    "data_quality": {"$ref": "obs.data_quality.v1.schema.json"}
  }
}
