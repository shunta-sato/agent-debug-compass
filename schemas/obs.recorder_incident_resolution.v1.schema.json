{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "obs.recorder_incident_resolution.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "incident_id",
    "incident_ref",
    "frozen_window_ref",
    "loss_report_ref",
    "coverage_ref",
    "trigger_decision_ref",
    "samples_ref",
    "log_source_status_ref",
    "log_events_ref",
    "blackout_report_ref",
    "marker",
    "trigger_event",
    "trigger_decision",
    "incident",
    "frozen_window",
    "data_quality"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["obs.recorder_incident_resolution.v1"]},
    "incident_id": {"type": "string", "minLength": 1},
    "incident_ref": {"type": "string", "pattern": "^artifact://recorder/incidents/[A-Za-z0-9][A-Za-z0-9_.-]*/incident\\.json$"},
    "frozen_window_ref": {"type": "string", "pattern": "^artifact://recorder/incidents/[A-Za-z0-9][A-Za-z0-9_.-]*/frozen_window\\.json$"},
    "loss_report_ref": {"type": "string", "pattern": "^artifact://recorder/incidents/[A-Za-z0-9][A-Za-z0-9_.-]*/loss_report\\.json$"},
    "coverage_ref": {"type": "string", "pattern": "^artifact://recorder/incidents/[A-Za-z0-9][A-Za-z0-9_.-]*/coverage\\.json$"},
    "trigger_decision_ref": {
      "type": ["string", "null"],
      "pattern": "^artifact://recorder/incidents/[A-Za-z0-9][A-Za-z0-9_.-]*/trigger_decision\\.json$"
    },
    "samples_ref": {"type": "string", "pattern": "^artifact://recorder/incidents/[A-Za-z0-9][A-Za-z0-9_.-]*/samples\\.jsonl$"},
    "log_source_status_ref": {
      "type": ["string", "null"],
      "pattern": "^artifact://recorder/incidents/[A-Za-z0-9][A-Za-z0-9_.-]*/log_source_status\\.json$"
    },
    "log_events_ref": {
      "type": ["string", "null"],
      "pattern": "^artifact://recorder/incidents/[A-Za-z0-9][A-Za-z0-9_.-]*/log_events\\.jsonl$"
    },
    "blackout_report_ref": {
      "type": ["string", "null"],
      "pattern": "^artifact://recorder/incidents/[A-Za-z0-9][A-Za-z0-9_.-]*/blackout_report\\.json$"
    },
    "marker": {
      "anyOf": [
        {"$ref": "obs.recorder_marker.v1.schema.json"},
        {"type": "null"}
      ]
    },
    "trigger_event": {
      "anyOf": [
        {"$ref": "obs.recorder_trigger_event.v1.schema.json"},
        {"type": "null"}
      ]
    },
    "trigger_decision": {
      "anyOf": [
        {"$ref": "obs.trigger_decision.v1.schema.json"},
        {"type": "null"}
      ]
    },
    "incident": {"$ref": "obs.recorder_incident.v1.schema.json"},
    "frozen_window": {"$ref": "obs.recorder_frozen_window.v1.schema.json"},
    "data_quality": {"$ref": "obs.data_quality.v1.schema.json"}
  }
}
