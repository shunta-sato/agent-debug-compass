[Unit]
Description=adc-targetd observation daemon
Documentation=file:/usr/share/doc/agent-debug-compass/target-setup.md
After=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/adc-targetd --service
Restart=on-failure
RestartSec=5s
User=adc-targetd
Group=adc-targetd
Environment=ADC_HOME=/var/lib/agent-debug-compass
StateDirectory=adc-targetd
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/var/lib/agent-debug-compass

[Install]
WantedBy=multi-user.target
